@admin_only
async def cmd_active_sessions(update: Update, context: ContextTypes.DEFAULT_TYPE):
    sessions = db.get_active_sessions()
    if not sessions:
        await update.message.reply_text("✅ <b>No active sessions.</b>", parse_mode=ParseMode.HTML)
        return
    lines = ["🔄 <b>Active Sessions</b>\n"]
    for s in sessions:
        lines.append(
            f"• UID <code>{s['user_id']}</code> | "
            f"<code>{esc(s['filename'])}</code> | "
            f"PID <code>{s['pid']}</code> | "
            f"Since <code>{s['started_at']}</code>"
        )
    await update.message.reply_text("\n".join(lines), parse_mode=ParseMode.HTML)


@admin_only
async def cmd_gen_code(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if len(context.args) < 2:
        await update.message.reply_text(
            "⚠️ Usage: <code>/gen_code &lt;credits&gt; &lt;max_uses&gt;</code>",
            parse_mode=ParseMode.HTML,
        )
        return
    try:
        amount, max_uses = int(context.args[0]), int(context.args[1])
        assert amount > 0 and max_uses > 0
    except (ValueError, AssertionError):
        await update.message.reply_text("❌ Both values must be positive integers.", parse_mode=ParseMode.HTML)
        return
    code = db.create_redeem_code(amount, max_uses)
    await update.message.reply_text(
        f"✅ <b>Code Created</b>\n\n"
        f"🎟️ Code: <code>{esc(code)}</code>\n"
        f"💳 Credits: <code>{amount}</code>\n"
        f"👥 Max Uses: <code>{max_uses}</code>",
        parse_mode=ParseMode.HTML,
    )


@admin_only
async def cmd_del_code(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not context.args:
        await update.message.reply_text("⚠️ Usage: <code>/del_code &lt;CODE&gt;</code>", parse_mode=ParseMode.HTML)
        return
    code = context.args[0].upper().strip()
    if db.delete_redeem_code(code):
        await update.message.reply_text(f"✅ Code <code>{esc(code)}</code> deleted.", parse_mode=ParseMode.HTML)
    else:
        await update.message.reply_text(f"❌ Code <code>{esc(code)}</code> not found.", parse_mode=ParseMode.HTML)


@admin_only
async def cmd_add_credits(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if len(context.args) < 2:
        await update.message.reply_text(
            "⚠️ Usage: <code>/add_credits &lt;user_id&gt; &lt;amount&gt;</code>",
            parse_mode=ParseMode.HTML,
        )
        return
    try:
        target_id, amount = int(context.args[0]), int(context.args[1])
        assert amount > 0
    except (ValueError, AssertionError):
        await update.message.reply_text("❌ Provide valid user_id and positive amount.", parse_mode=ParseMode.HTML)
        return
    if not db.get_user(target_id):
        await update.message.reply_text(f"❌ User <code>{target_id}</code> not found.", parse_mode=ParseMode.HTML)
        return
    new_bal = db.add_credits(target_id, amount)
    await update.message.reply_text(
        f"✅ Added <b>{amount}</b> credits to <code>{target_id}</code>.\n"
        f"💳 New balance: <code>{new_bal}</code>",
        parse_mode=ParseMode.HTML,
    )


@admin_only
async def cmd_block(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not context.args:
        await update.message.reply_text("⚠️ Usage: <code>/block &lt;user_id&gt;</code>", parse_mode=ParseMode.HTML)
        return
    try:
        target_id = int(context.args[0])
    except ValueError:
        await update.message.reply_text("❌ Invalid user ID.", parse_mode=ParseMode.HTML)
        return
    if target_id == ADMIN_ID:
        await update.message.reply_text("❌ Cannot block the admin.", parse_mode=ParseMode.HTML)
        return
    if db.block_user(target_id):
        await update.message.reply_text(f"🚫 User <code>{target_id}</code> <b>blocked</b>.", parse_mode=ParseMode.HTML)
    else:
        await update.message.reply_text(f"❌ User <code>{target_id}</code> not found.", parse_mode=ParseMode.HTML)


