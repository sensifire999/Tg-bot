@registered
async def callback_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    data = query.data
    user = update.effective_user
    user_data = db.get_user(user.id)
    back_btn = InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Back", callback_data="cb_back")]])

    if data == "cb_profile":
        if not user_data:
            await query.edit_message_text("Please /start first.")
            return
        text = (
            "👤 <b>Your Profile</b>\n"
            "─────────────────────\n"
            f"🆔 <b>ID:</b> <code>{user_data['user_id']}</code>\n"
            f"📛 <b>Name:</b> {esc(user_data['full_name'])}\n"
            f"🔖 <b>Username:</b> @{esc(user_data['username']) if user_data['username'] else 'N/A'}\n"
            f"💳 <b>Credits:</b> <code>{user_data['credits']}</code>\n"
            f"▶️ <b>Total Runs:</b> <code>{user_data['total_runs']}</code>\n"
            f"📅 <b>Joined:</b> <code>{user_data['joined_at']}</code>"
        )
        await query.edit_message_text(text, parse_mode=ParseMode.HTML, reply_markup=back_btn)

    elif data == "cb_redeem":
        await query.edit_message_text(
            "🎟️ <b>Redeem a Code</b>\n\nUse the command:\n<code>/redeem YOUR_CODE_HERE</code>",
            parse_mode=ParseMode.HTML,
            reply_markup=back_btn,
        )

    elif data == "cb_help":
        text = (
            "📖 <b>Help</b>\n"
            "─────────────────────\n"
            "• Send a <code>.py</code> file to run it\n"
            "• <b>1 credit</b> per 60-second block (min 1)\n"
            f"• Timeout: <b>{EXECUTION_TIMEOUT}s</b>\n"
            "• Forbidden code is blocked automatically\n\n"
            "<b>Commands:</b>\n"
            "/profile  /credits  /redeem  /help"
        )
        await query.edit_message_text(text, parse_mode=ParseMode.HTML, reply_markup=back_btn)

    elif data == "cb_mystats":
        if not user_data:
            await query.edit_message_text("No data found.")
            return
        text = (
            "📊 <b>My Stats</b>\n"
            "─────────────────────\n"
            f"💳 <b>Credits:</b> <code>{user_data['credits']}</code>\n"
            f"▶️ <b>Total Runs:</b> <code>{user_data['total_runs']}</code>\n"
            f"📅 <b>Member Since:</b> <code>{user_data['joined_at']}</code>"
        )
        await query.edit_message_text(text, parse_mode=ParseMode.HTML, reply_markup=back_btn)

    elif data == "cb_back":
        credits = user_data["credits"] if user_data else 0
        text = (
            f"👋 Welcome back, <b>{esc(user.full_name)}</b>!\n\n"
            f"💳 <b>Credits:</b> <code>{credits}</code>\n\n"
            "Use the buttons below to navigate:"
        )
        await query.edit_message_text(text, parse_mode=ParseMode.HTML, reply_markup=build_main_menu())


# ─────────────────────────────────────────────────────────────────────────────
# .py file execution handler
# ─────────────────────────────────────────────────────────────────────────────

@registered
async def handle_python_file(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    document = update.message.document
    filename = document.file_name or "script.py"

    if not filename.lower().endswith(".py"):
        await update.message.reply_text(
            "⚠️ Please send a valid <code>.py</code> file.",
            parse_mode=ParseMode.HTML,
        )
        return

    balance = db.get_credits(user.id)
    if balance < 1:
        await update.message.reply_text(
            "❌ <b>Insufficient Credits!</b>\n\n"
            "You need at least <b>1 credit</b> to run code.\n"
            "Use <code>/redeem &lt;CODE&gt;</code> to top up.",
            parse_mode=ParseMode.HTML,
        )
        return

    # Create isolated sandbox
    run_id = str(uuid.uuid4())
    sandbox_dir = os.path.join(SANDBOX_BASE, f"coderunner_{run_id}")
    os.makedirs(sandbox_dir, exist_ok=True)
    script_path = os.path.join(sandbox_dir, f"script_{run_id}.py")

    try:
        tg_file = await document.get_file()
        await tg_file.download_to_drive(script_path)
    except Exception as exc:
        shutil.rmtree(sandbox_dir, ignore_errors=True)
        await update.message.reply_text(
            f"❌ Download failed: <code>{esc(str(exc))}</code>",
            parse_mode=ParseMode.HTML,
        )
        return

    # Security scan
    try:
        is_safe, violations = security.scan_file(script_path)
    except Exception as exc:
        shutil.rmtree(sandbox_dir, ignore_errors=True)
        await update.message.reply_text(
            f"❌ Scan error: <code>{esc(str(exc))}</code>",
            parse_mode=ParseMode.HTML,
        )
        return

    if not is_safe:
        shutil.rmtree(sandbox_dir, ignore_errors=True)
        lines = "\n".join(f"  • <code>{esc(v)}</code>" for v in violations[:10])
        await update.message.reply_text(
            f"🚫 <b>Security Scan Failed!</b>\n\nForbidden patterns:\n{lines}",
            parse_mode=ParseMode.HTML,
        )
        return

    status_msg = await update.message.reply_text(
        f"⏳ <b>Executing</b> <code>{esc(filename)}</code>...\n"
        f"💳 Balance: <code>{balance}</code>  |  ⏱ Timeout: <code>{EXECUTION_TIMEOUT}s</code>",
        parse_mode=ParseMode.HTML,
    )

    db.add_active_session(user.id, filename, -1)
    start_time = time.monotonic()
    timed_out = False

    try:
        process = subprocess.Popen(
            ["python3", script_path],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            cwd=sandbox_dir,
            env={"PATH": "/usr/local/bin:/usr/bin:/bin", "HOME": sandbox_dir},
        )
        db.add_active_session(user.id, filename, process.pid)
        try:
            stdout_bytes, stderr_bytes = process.communicate(timeout=EXECUTION_TIMEOUT)
        except subprocess.TimeoutExpired:
            process.kill()
            stdout_bytes, stderr_bytes = process.communicate()
            timed_out = True
        return_code = process.returncode
    except Exception as exc:
        db.remove_active_session(user.id)
        shutil.rmtree(sandbox_dir, ignore_errors=True)
        await status_msg.edit_text(
            f"❌ <b>Runtime error:</b> <code>{esc(str(exc))}</code>",
            parse_mode=ParseMode.HTML,
        )
        return
    finally:
        db.remove_active_session(user.id)

    duration = time.monotonic() - start_time
    credits_used = compute_credits(duration)

    if not db.deduct_credits(user.id, credits_used):
        db.deduct_credits(user.id, balance)  # deduct whatever is left
        credits_used = balance

    new_balance = db.get_credits(user.id)
    db.log_execution(user.id, filename, credits_used, duration, return_code == 0)

    MAX_OUT = 3000
    stdout_text = stdout_bytes.decode("utf-8", errors="replace").strip()
    stderr_text = stderr_bytes.decode("utf-8", errors="replace").strip()

    def section(text: str, label: str) -> str:
        if not text:
            return ""
        if len(text) > MAX_OUT:
            text = text[:MAX_OUT] + f"\n…[{len(text)} chars, truncated]"
        return f"\n<b>{label}</b>\n<code>{esc(text)}</code>"

    icon = "✅" if (return_code == 0 and not timed_out) else ("⏰" if timed_out else "❌")
    label = "Success" if (return_code == 0 and not timed_out) else ("Timed Out" if timed_out else f"Error (exit {return_code})")

    result = (
        f"{icon} <b>Execution {label}</b>\n"
        f"📄 File: <code>{esc(filename)}</code>\n"
        f"⏱ Duration: <code>{duration:.2f}s</code>\n"
        f"💳 Credits used: <code>{credits_used}</code>  →  Balance: <code>{new_balance}</code>"
    )
    if timed_out:
        result += f"\n⚠️ Killed after <code>{EXECUTION_TIMEOUT}s</code>."
    result += section(stdout_text, "📤 Output:")
    result += section(stderr_text, "⚠️ Stderr:")
    if not stdout_text and not stderr_text:
        result += "\n<i>(No output produced)</i>"

    if len(result) > 4000:
        result = result[:4000] + "\n…<i>[truncated]</i>"

    await status_msg.edit_text(result, parse_mode=ParseMode.HTML)
    shutil.rmtree(sandbox_dir, ignore_errors=True)


